# Copy to `.env` in this directory (optional). All variables use the `RAG_` prefix.

# Dataset
# RAG_DATASET_NAME=sentence-transformers/NQ-retrieval
# RAG_DATASET_SPLIT=train
# RAG_DATASET_STREAMING=1   # default on; avoids HF CastError when hub Features omit optional columns
# RAG_INGEST_PROGRESS=1     # tqdm row progress during ingest (off under pytest; set 0 to disable)
# RAG_MAX_PASSAGES=5000     # cap expanded passages for local/CI runs (Milestone 2)
# RAG_FORCE_INGEST=1       # rebuild silver even when ingest_manifest matches (Milestone 2)

# Embeddings / dense batching (Milestone 2)
# RAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# RAG_EMBEDDING_BATCH_SIZE=64   # sentence-transformers encode batch size (raise until OOM on GPU)
# RAG_DENSE_READ_BATCH_LINES=512  # silver JSONL lines per encode+upsert chunk before clearing RAM

# Qdrant (dense + sparse vectors, Milestone 2.2)
# RAG_QDRANT_URL=http://localhost:6333
# RAG_QDRANT_COLLECTION=nq_passages
# RAG_QDRANT_SPARSE_VECTOR_NAME=sparse
# RAG_SPARSE_UPSERT_BATCH_SIZE=256
# RAG_SPARSE_WORKERS=1
# RAG_SPARSE_WRITE_CONCURRENCY=1
# RAG_SPARSE_CHECKPOINT_FILE=sparse_checkpoint.json
# RAG_BM25_K1=1.5
# RAG_BM25_B=0.75
# RAG_BM25_EPSILON=0.25
# RAG_DOCTOR_CHECK_QDRANT=1   # add GET /readyz check to `python -m src.scripts.doctor`

# Artifacts directory (passages.jsonl, sparse_index_manifest.json, index_manifest.json)
# RAG_OUTPUT_DIR=artifacts
