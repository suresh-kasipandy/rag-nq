# Copy to `.env` in this directory (optional). All variables use the `RAG_` prefix.
# Scripts load `.env` automatically via Settings.from_env(); shell variables still take precedence.

# Dataset
# RAG_DATASET_NAME=sentence-transformers/NQ-retrieval
# RAG_DATASET_SPLIT=train
# RAG_DATASET_STREAMING=1   # default on; avoids HF CastError when hub Features omit optional columns
# RAG_INGEST_PROGRESS=1     # tqdm row progress during ingest (off under pytest; set 0 to disable)
# RAG_MAX_RAW_ROWS=30000    # cap raw HF rows
# RAG_MAX_CHUNK_ROWS=30000  # cap raw rows chunked into index_chunks.jsonl
# RAG_MAX_INDEX_ROWS=30000  # cap chunk artifact rows indexed/retrieved
# RAG_MAX_PASSAGES=5000     # deprecated flat-passage cap; prefer row caps above
# RAG_FORCE_INGEST=1       # rebuild silver even when ingest_manifest matches (Milestone 2)
# RAG_FORCE_RAW_INGEST=1   # rebuild raw_dataset.jsonl even when raw manifest matches

# Embeddings / dense batching (Milestone 2)
# RAG_EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
# RAG_EMBEDDING_BATCH_SIZE=64   # sentence-transformers encode batch size (raise until OOM on GPU)
# RAG_DENSE_READ_BATCH_LINES=512  # index_chunks JSONL lines per encode+upsert chunk before clearing RAM

# Qdrant (dense + sparse vectors, Milestone 2.2)
# RAG_QDRANT_URL=http://localhost:6333
# RAG_QDRANT_COLLECTION=nq_passages_bge_base_v15
# RAG_QDRANT_SPARSE_VECTOR_NAME=sparse
# RAG_SPARSE_UPSERT_BATCH_SIZE=256
# RAG_SPARSE_WORKERS=1
# RAG_SPARSE_WRITE_CONCURRENCY=1
# RAG_SPARSE_CHECKPOINT_FILE=sparse_checkpoint.json
# RAG_BM25_K1=1.5
# RAG_BM25_B=0.75
# RAG_BM25_EPSILON=0.25
# RAG_DOCTOR_CHECK_QDRANT=1   # add GET /readyz check to `python -m src.scripts.doctor`

# Retrieval + reranking (Milestone 4)
# RAG_RETRIEVE_K=300
# RAG_RERANK_ENABLED=1
# RAG_RERANK_K=30
# RAG_RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# RAG_RERANK_CONTEXT_TOKEN_BUDGET=384
# RAG_RETRIEVAL_DEDUPE_ENABLED=1

# Grounded generation (Milestone 5)
# RAG_GENERATION_PROVIDER=heuristic  # heuristic | http_json | openai
# RAG_GENERATION_MODEL_NAME=local-grounded-heuristic
# For OpenAI, set provider=openai and use an OpenAI chat model such as gpt-4o-mini.
# RAG_GENERATION_TEMPERATURE=0
# RAG_GENERATION_MAX_TOKENS=512
# RAG_GENERATION_TIMEOUT_SECONDS=30
# RAG_GENERATION_CONTEXT_TOKEN_BUDGET=1500
# RAG_GENERATION_MIN_CITATIONS=1
# RAG_GENERATION_API_URL=          # for openai defaults to https://api.openai.com/v1/chat/completions
# RAG_GENERATION_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_API_KEY=                 # optional local secret; shell exports still take precedence

# Artifacts directory (raw_dataset.jsonl, index_chunks.jsonl, manifests, checkpoints)
# RAG_OUTPUT_DIR=artifacts
