# Byte-compiled / optimized
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# Test & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers & linters
.mypy_cache/
.ruff_cache/

# Local env & secrets (keep `.env.example` tracked)
.env
.env.local
*.pem

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Project build artifacts (indexes, passages, manifest)
artifacts/

# Optional: Hugging Face cache when set to repo-local (e.g. HF_HOME)
.hf_cache/

# Logs
*.log

# Notebooks
*.ipynb